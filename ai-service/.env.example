# ── Groq AI ───────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model to use (change to swap models without touching code)
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | openai/gpt-oss-120b
GROQ_MODEL=llama-3.3-70b-versatile

# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Optional: Direct Postgres connection ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:your_db_password@db.your-project-ref.supabase.co:5432/postgres

# ── CORS (set in production) ──────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_URL=https://your-backend.railway.app
